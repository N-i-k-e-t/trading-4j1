// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  rules     Rule[]
  trades    Trade[]
  journals  Journal[]
  sessions  Session[]
  settings  Settings?
  createdAt DateTime @default(now())
}

model Rule {
  id        String   @id @default(uuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Trade {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          String   // Storing as string to match current app's date handling (YYYY-MM-DD)
  pair          String
  type          String   // 'Long', 'Short'
  entry         String
  exit          String
  followedRules Boolean  @default(true)
  emotion       String
  notes         String?
}

model Journal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  title     String
  content   String
  mood      String
}

model Session {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date               String
  emotionalBaseline  String
  rulesLocked        Boolean  @default(true)
  tradesTaken        Int      @default(0)
  tradesAllowed      Int      @default(3)
  stabilityScore     Int      @default(85)
  preSessionComplete Boolean  @default(false)
  notes              String?
}

model Settings {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  maxTrades       Int     @default(3)
  sessionStart    String  @default("09:30")
  sessionEnd      String  @default("16:00")
  reminders       Boolean @default(true)
  preSessionCheck Boolean @default(true)
  darkMode        Boolean @default(true)
}
